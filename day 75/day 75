#include <stdio.h>

int main() {
    int arr[] = {15, -2, 2, -8, 1, 7, 10, 23};
    int n = sizeof(arr) / sizeof(arr[0]);

    int maxLen = 0, sum = 0;

    // Hash array (for simplicity, using large size)
    int hash[10000];
    for (int i = 0; i < 10000; i++) hash[i] = -1;

    for (int i = 0; i < n; i++) {
        sum += arr[i];

        // Case 1: sum = 0 → subarray from 0 to i
        if (sum == 0) {
            maxLen = i + 1;
        }

        // Case 2: sum seen before
        if (hash[sum + 5000] != -1) {
            int len = i - hash[sum + 5000];
            if (len > maxLen)
                maxLen = len;
        } else {
            // Store first occurrence
            hash[sum + 5000] = i;
        }
    }

    printf("%d", maxLen);

    return 0;
}
