#include <stdio.h>
#include <stdlib.h>

// Define structure
struct Node {
    int data;
    struct Node* next;
};

int main() {
    int n;
    
    printf("Enter number of nodes: ");
    scanf("%d", &n);
    
    struct Node *head = NULL, *temp = NULL, *newNode = NULL;
    
    printf("Enter elements:\n");
    
    for(int i = 0; i < n; i++) {
        newNode = (struct Node*)malloc(sizeof(struct Node));
        
        scanf("%d", &newNode->data);
        newNode->next = NULL;
        
        if(head == NULL) {
            head = newNode;
            temp = newNode;
        } else {
            temp->next = newNode;
            temp = newNode;
        }
    }
    
    // Traversing the list
    printf("Linked List: ");
    temp = head;
    while(temp != NULL) {
        printf("%d ", temp->data);
        temp = temp->next;
    }
    
    return 0;
}
