#include <stdio.h>

int main() {
    int n, m, u, v;

    // Input vertices and edges
    scanf("%d", &n);
    scanf("%d", &m);

    int adj[n][n];

    // Initialize matrix with 0
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            adj[i][j] = 0;

    // Input edges
    for (int i = 0; i < m; i++) {
        scanf("%d %d", &u, &v);

        adj[u][v] = 1;   // edge from u to v

        // For undirected graph, also add reverse edge
        adj[v][u] = 1;
    }

    // Print adjacency matrix
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            printf("%d ", adj[i][j]);
        }
        printf("\n");
    }

    return 0;
}
